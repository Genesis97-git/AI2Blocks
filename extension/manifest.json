{
  "manifest_version": 3,
  "name": "AI2Blocks",
  "version": "0.3.0",
  "description": "Generate MIT App Inventor blocks from AI-generated descriptions.",
  "permissions": ["scripting", "activeTab"],
  "host_permissions": [
    "https://ai2.appinventor.mit.edu/*",
    "https://ai2-test.appinventor.mit.edu/*",
	"https://ai2a.appinventor.mit.edu/*",
	"https://code2.appinventor.mit.edu/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI2Blocks"
  },
  "content_scripts": [
    {
      "matches": [
        "https://ai2.appinventor.mit.edu/*",
        "https://ai2-test.appinventor.mit.edu/*",
		"https://ai2a.appinventor.mit.edu/*",
		"https://code2.appinventor.mit.edu/*"
      ],
      "js": ["js/content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["js/injected.js"],
      "matches": [
        "https://ai2.appinventor.mit.edu/*",
        "https://ai2-test.appinventor.mit.edu/*",
		"https://ai2a.appinventor.mit.edu/*",
		"https://code2.appinventor.mit.edu/*"
      ]
    }
  ]
}